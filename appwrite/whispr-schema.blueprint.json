{
  "projectName": "Whispr",
  "database": {
    "id": "whispr",
    "name": "Whispr"
  },
  "collections": [
    {
      "id": "users",
      "name": "Users",
      "documentSecurity": true,
      "attributes": [
        { "key": "userId", "type": "string", "size": 64, "required": true },
        { "key": "username", "type": "string", "size": 64, "required": true },
        { "key": "usernameLower", "type": "string", "size": 64, "required": true },
        { "key": "email", "type": "string", "size": 255, "required": true },
        { "key": "publicKey", "type": "string", "size": 16384, "required": false },
        { "key": "activePublicKeyId", "type": "string", "size": 128, "required": false },
        { "key": "hasPublicKey", "type": "boolean", "required": true },
        { "key": "hasPrivateKeyBackup", "type": "boolean", "required": true },
        { "key": "updatedAt", "type": "string", "size": 64, "required": true }
      ],
      "indexes": [
        { "key": "users_userId", "type": "key", "attributes": ["userId"], "orders": ["ASC"] },
        { "key": "users_usernameLower_key", "type": "key", "attributes": ["usernameLower"], "orders": ["ASC"] },
        { "key": "users_usernameLower_unique", "type": "unique", "attributes": ["usernameLower"], "orders": ["ASC"] }
      ]
    },
    {
      "id": "user_keys",
      "name": "User Keys",
      "documentSecurity": true,
      "attributes": [
        { "key": "keyId", "type": "string", "size": 128, "required": true },
        { "key": "userId", "type": "string", "size": 64, "required": true },
        { "key": "username", "type": "string", "size": 64, "required": true },
        { "key": "publicKey", "type": "string", "size": 16384, "required": true },
        { "key": "isActive", "type": "boolean", "required": true },
        { "key": "revokedAt", "type": "string", "size": 64, "required": false },
        { "key": "updatedAt", "type": "string", "size": 64, "required": true }
      ],
      "indexes": [
        { "key": "user_keys_keyId", "type": "key", "attributes": ["keyId"], "orders": ["ASC"] },
        { "key": "user_keys_userId", "type": "key", "attributes": ["userId"], "orders": ["ASC"] }
      ]
    },
    {
      "id": "private_key_backups",
      "name": "Private Key Backups",
      "documentSecurity": true,
      "attributes": [
        { "key": "userId", "type": "string", "size": 64, "required": true },
        { "key": "ciphertext", "type": "string", "size": 65535, "required": true },
        { "key": "salt", "type": "string", "size": 512, "required": true },
        { "key": "iv", "type": "string", "size": 512, "required": true },
        { "key": "version", "type": "string", "size": 128, "required": true },
        { "key": "updatedAt", "type": "string", "size": 64, "required": true }
      ],
      "indexes": [
        { "key": "private_key_backups_userId", "type": "key", "attributes": ["userId"], "orders": ["ASC"] }
      ]
    },
    {
      "id": "messages",
      "name": "Messages",
      "documentSecurity": true,
      "attributes": [
        { "key": "conversationKey", "type": "string", "size": 255, "required": true },
        { "key": "participantIds", "type": "string[]", "size": 64, "required": true },
        { "key": "senderId", "type": "string", "size": 64, "required": true },
        { "key": "receiverId", "type": "string", "size": 64, "required": true },
        { "key": "senderUsername", "type": "string", "size": 64, "required": true },
        { "key": "receiverUsername", "type": "string", "size": 64, "required": true },
        { "key": "senderKeyId", "type": "string", "size": 128, "required": true },
        { "key": "receiverKeyId", "type": "string", "size": 128, "required": true },
        { "key": "ciphertext", "type": "string", "size": 65535, "required": true },
        { "key": "nonce", "type": "string", "size": 512, "required": true },
        { "key": "salt", "type": "string", "size": 512, "required": true },
        { "key": "version", "type": "string", "size": 128, "required": true },
        { "key": "tampered", "type": "boolean", "required": true },
        { "key": "createdAt", "type": "string", "size": 64, "required": true }
      ],
      "indexes": [
        { "key": "messages_conversationKey", "type": "key", "attributes": ["conversationKey"], "orders": ["ASC"] },
        { "key": "messages_createdAt", "type": "key", "attributes": ["createdAt"], "orders": ["ASC"] },
        { "key": "messages_participantIds", "type": "key", "attributes": ["participantIds"], "orders": ["ASC"] }
      ]
    }
  ]
}
